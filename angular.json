{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": "117014e9-265e-495e-bca7-12b00075ed73"
  },
  "newProjectRoot": "projects",
  "projects": {
    "sabr-frontend": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/sabr-client",
            "index": "src/index.html",
            "main": "src/main.client.ts",
            "serviceWorker": false,
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "tsconfig.client.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "public",
                "output": "."
              }
            ],
            "styles": [
              "src/styles.scss"
            ],
            "allowedCommonJsDependencies": [
              "eva-icons"
            ]
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.production.ts"
                }
              ],
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1.5MB",
                  "maximumError": "2.5MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "10kB",
                  "maximumError": "16kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            },
            "admin-production": {
              "outputPath": "dist/sabr-admin",
              "main": "src/main.admin.ts",
              "tsConfig": "tsconfig.admin.json",
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.production.ts"
                }
              ],
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1.5MB",
                  "maximumError": "2.5MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "10kB",
                  "maximumError": "16kB"
                }
              ],
              "outputHashing": "all"
            },
            "admin-development": {
              "outputPath": "dist/sabr-admin",
              "main": "src/main.admin.ts",
              "tsConfig": "tsconfig.admin.json",
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            },
            "client-dev-deploy": {
              "outputPath": "dist/sabr-client",
              "main": "src/main.client.ts",
              "tsConfig": "tsconfig.client.json",
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.client.dev.ts"
                }
              ],
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1.5MB",
                  "maximumError": "2.5MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "10kB",
                  "maximumError": "16kB"
                }
              ],
              "outputHashing": "all"
            },
            "client-prod-deploy": {
              "outputPath": "dist/sabr-client",
              "main": "src/main.client.ts",
              "tsConfig": "tsconfig.client.json",
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.client.prod.ts"
                }
              ],
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1.5MB",
                  "maximumError": "2.5MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "10kB",
                  "maximumError": "16kB"
                }
              ],
              "outputHashing": "all"
            },
            "admin-dev-deploy": {
              "outputPath": "dist/sabr-admin",
              "main": "src/main.admin.ts",
              "tsConfig": "tsconfig.admin.json",
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.admin.dev.ts"
                }
              ],
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1.5MB",
                  "maximumError": "2.5MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "10kB",
                  "maximumError": "16kB"
                }
              ],
              "outputHashing": "all"
            },
            "admin-prod-deploy": {
              "outputPath": "dist/sabr-admin",
              "main": "src/main.admin.ts",
              "tsConfig": "tsconfig.admin.json",
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.admin.prod.ts"
                }
              ],
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1.5MB",
                  "maximumError": "2.5MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "10kB",
                  "maximumError": "16kB"
                }
              ],
              "outputHashing": "all"
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "buildTarget": "sabr-frontend:build:development",
            "proxyConfig": "proxy.client.conf.json"
          },
          "configurations": {
            "production": {
              "buildTarget": "sabr-frontend:build:production"
            },
            "development": {
              "buildTarget": "sabr-frontend:build:development",
              "proxyConfig": "proxy.client.conf.json"
            },
            "admin-development": {
              "buildTarget": "sabr-frontend:build:admin-development",
              "proxyConfig": "proxy.admin.conf.json",
              "port": 4300
            },
            "admin-production": {
              "buildTarget": "sabr-frontend:build:admin-production"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "tsconfig.spec.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "public",
                "output": "."
              }
            ],
            "styles": [
              "src/styles.scss"
            ]
          }
        }
      }
    }
  }
}

